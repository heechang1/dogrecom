# Optional: override demo gate password (default: 1234)
# NEXT_PUBLIC_APP_PASSWORD=your-secret

# OpenAI ( /api/ai-test, /ai-test 페이지 )
# OPENAI_API_KEY=sk-...

# Google Cloud Vision — /api/food/ocr 에서 DOCUMENT_TEXT_DETECTION 우선 사용 (미설정 시 Tesseract)
# GOOGLE_VISION_API_KEY=...
# (선택) 동일 키를 API_KEY 로만 두어도 인식합니다. 우선순위: GOOGLE_VISION_API_KEY > API_KEY

# 급여 기록 QR에 넣을 절대 URL (미설정 시 상대 경로만 사용 → 하이드레이션 일치)
# 예: http://192.168.0.10:3000 또는 배포 도메인
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
